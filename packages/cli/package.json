{
  "name": "@yr-kits/cli",
  "version": "0.1.7",
  "description": "프론트엔드 프로젝트에 유틸리티, 훅, 타입, 설정 파일을 추가하는 CLI",
  "type": "module",
  "bin": {
    "yr-kits": "./dist/cli.mjs"
  },
  "main": "./dist/cli.mjs",
  "exports": {
    ".": {
      "import": "./dist/cli.mjs",
      "default": "./dist/cli.mjs"
    },
    "./utils/ime-enter-handler": {
      "import": "./dist/utils/ime-enter-handler.mjs",
      "default": "./dist/utils/ime-enter-handler.mjs"
    }
  },
  "scripts": {
    "build": "tsdown && ./scripts/copy-templates.sh",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm run build",
    "test": "tsdown src/**/*.test.ts --format esm --out-dir /tmp/yr-kits-cli-tests --clean && node --test /tmp/yr-kits-cli-tests/*.test.mjs",
    "release:patch": "npm version patch --no-git-tag-version && pnpm publish --access public --no-git-checks",
    "release:minor": "npm version minor --no-git-tag-version && pnpm publish --access public --no-git-checks",
    "release:major": "npm version major --no-git-tag-version && pnpm publish --access public --no-git-checks"
  },
  "keywords": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1eeyerin/yr-kits.git"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.10",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.2"
  }
}
