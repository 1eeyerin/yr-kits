{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["message", "changes", "warnings"],
  "properties": {
    "message": {
      "type": "string"
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "oldText", "newText"],
        "properties": {
          "path": {
            "type": "string"
          },
          "oldText": {
            "type": "string"
          },
          "newText": {
            "type": "string"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
